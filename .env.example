# --- GLOBAL PLATFORM SETTINGS ---
APP_ENV=development
API_PREFIX=api
API_VERSION=v1
APP_PORT=3001

# --- MAIN DATABASE (Tenant Registry) ---
MAIN_DB_HOST=localhost
MAIN_DB_PORT=5432
MAIN_DB_USERNAME=postgres
MAIN_DB_PASSWORD=postgres
MAIN_DB_NAME=saas_main

# --- REDIS (Cache & Sessions) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- AUTHENTICATION ---
JWT_SECRET=super_secret_jwt_key_example
JWT_REFRESH_SECRET=super_secret_refresh_key_example
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS ---
CORS_ORIGIN=http://localhost:3000

# --- TENANT CONFIG ---
TENANT_MAX_CONNECTIONS=50
TENANT_IDLE_TIMEOUT_MS=1800000
TENANT_CACHE_TTL_SECONDS=300
