# ===================================
# Multi-Tenant SaaS Platform
# Environment Configuration Template
# ===================================

# Application
APP_PORT=3001
APP_ENV=development
APP_NAME=SaaS Platform
API_PREFIX=api
API_VERSION=v1

# Main Database (Tenant Registry)
MAIN_DB_HOST=localhost
MAIN_DB_PORT=5432
MAIN_DB_USERNAME=postgres
MAIN_DB_PASSWORD=changeme
MAIN_DB_NAME=saas_main

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Tenant Connection Pool
TENANT_MAX_CONNECTIONS=50
TENANT_IDLE_TIMEOUT_MS=1800000
TENANT_CACHE_TTL_SECONDS=300

# Cors
CORS_ORIGIN=http://localhost:3000
